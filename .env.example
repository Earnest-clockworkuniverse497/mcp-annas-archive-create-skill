# Anna's Archive member auth — get from your account at https://annas-archive.gl/account
ANNAS_ACCOUNT_KEY=<paste-account-id>
ANNAS_BASE_URL=https://annas-archive.gl

# Google AI Studio key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<paste-gemini-key>
GEMINI_MODEL=gemini-3-flash-preview

# Where downloaded books and skill drafts are stored
DATA_DIR=./data

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Outbound proxy for Anna's Archive traffic only
# ─────────────────────────────────────────────────────────────────────────────
# Routes ONLY anna's-archive.gl + partner-server downloads through a proxy.
# Gemini API calls stay direct. Useful if your server IP is blocked, or you
# want to exit through a different country.
#
# Supported schemes: http, https, socks5 (also socks4, socks5h)
# Format:            <scheme>://[user:pass@]host:port
#
# Examples:
#   ANNAS_HTTPS_PROXY=http://corp-proxy.local:8080
#   ANNAS_HTTPS_PROXY=https://user:pass@proxy.example.com:443
#   ANNAS_HTTPS_PROXY=socks5://127.0.0.1:1080
#   ANNAS_HTTPS_PROXY=socks5://user:pass@residential.proxy.io:1080
#
# Falls back to HTTPS_PROXY / HTTP_PROXY env vars if ANNAS_HTTPS_PROXY is unset.
# Leave commented for direct traffic.
#
# ANNAS_HTTPS_PROXY=socks5://127.0.0.1:1080

# ─────────────────────────────────────────────────────────────────────────────
# WireGuard note
# ─────────────────────────────────────────────────────────────────────────────
# WG is a system-level VPN, not an app-level proxy. Two ways to use it:
#
#   A) System-wide: bring up WG with `wg-quick up <name>` so the whole host
#      routes through it. No app config needed; mcp-books traffic follows
#      system routing.
#
#   B) Scoped: run mcp-books inside a network namespace where the WG iface
#      is the default route:
#         ip netns add anna
#         ip netns exec anna wg-quick up <conf>
#         ip netns exec anna node dist/index.js
#      Again, no app config needed.
#
#   C) Via a WG → SOCKS5 bridge (e.g. `gost`, `microsocks` listening on
#      127.0.0.1 inside WG namespace, exposed to host): set
#      ANNAS_HTTPS_PROXY=socks5://127.0.0.1:<port>
